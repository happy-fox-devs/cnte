{
  "manifest_version": 3,
  "name": "Custom New Tab",
  "version": "0.0.1",
  "description": "A beautiful custom new tab page with widgets and search",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage"
  ]
}
